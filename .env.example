# Example environment configuration for local development
# Copy this file to ".env" and adjust values if needed

# -------------------------
# MySQL (Docker - local development)
# -------------------------
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=the_duckers
MYSQL_USER=duckers
MYSQL_PASSWORD=duckerspass
MYSQL_PORT=3306

# -------------------------
# MongoDB (Docker - local development)
# -------------------------
MONGO_INITDB_DATABASE=the_duckers_catalog
MONGO_PORT=27017

# Optional: Enable MongoDB authentication if needed
# MONGO_INITDB_ROOT_USERNAME=root
# MONGO_INITDB_ROOT_PASSWORD=root

# -------------------------
# Container names (stable)
# -------------------------
MYSQL_CONTAINER_NAME=duckers-mysql
MONGO_CONTAINER_NAME=duckers-mongo

# -------------------------
# Optional: Application ports
# -------------------------
BACKEND_PORT=8080
FRONTEND_PORT=5173